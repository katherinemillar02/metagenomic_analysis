process Metaphlan {
    // Reduce CPU usage if needed
    cpus = 6
    memory = '32 GB'
    
    // Remove the Bowtie2 database requirement
    script: """
        metaphlan \\
            --input_type fastq \\
            --nproc 6 \\
            NH_12_01_nohost_R1.fastq.gz,NH_12_01_nohost_R2.fastq.gz \\
            --biom NH_12_01_nohost_mpa_v30.metaphlan.biom \\
            --output_file NH_12_01_nohost_mpa_v30.metaphlan_profile.txt
    """
}